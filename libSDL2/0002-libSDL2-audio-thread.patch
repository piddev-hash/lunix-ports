diff --git a/tmp/sdl2patch.ytXjUk/current/src/audio/lunix/SDL_lunixaudio.c b/src/audio/lunix/SDL_lunixaudio.c
new file mode 100644
index 0000000..220fcc2
--- /dev/null
+++ b/src/audio/lunix/SDL_lunixaudio.c
@@ -0,0 +1,227 @@
+#include "../../SDL_internal.h"
+
+#if SDL_AUDIO_DRIVER_LUNIX
+
+#include <devctl.h>
+#include <errno.h>
+#include <fcntl.h>
+#include <lunix/audio.h>
+#include <string.h>
+#include <unistd.h>
+
+#include "SDL_audio.h"
+#include "SDL_timer.h"
+#include "../SDL_audio_c.h"
+#include "SDL_lunixaudio.h"
+
+static const char *lunixAudioDevice = "/dev/audio";
+
+static int
+LUNIXAUDIO_GetBufferInfo(_THIS, struct audio_buffer_info *bufferInfo)
+{
+    int info = -1;
+
+    errno = posix_devctl(this->hidden->audio_fd, AUDIO_GET_BUFFER_INFO,
+            bufferInfo, sizeof(*bufferInfo), &info);
+    if (errno != 0 || info != 0) {
+        return -1;
+    }
+
+    return 0;
+}
+
+static void
+LUNIXAUDIO_WaitDevice(_THIS)
+{
+    struct audio_buffer_info bufferInfo;
+    Uint32 delay;
+
+    if (this->hidden->bytes_per_second == 0) {
+        return;
+    }
+
+    while (LUNIXAUDIO_GetBufferInfo(this, &bufferInfo) == 0) {
+        if (bufferInfo.queued <= this->hidden->target_queue_bytes) {
+            return;
+        }
+
+        delay = (Uint32) ((((Uint64) bufferInfo.queued -
+                this->hidden->target_queue_bytes) * 1000) /
+                this->hidden->bytes_per_second);
+        SDL_Delay(delay ? delay : 1);
+    }
+
+    delay = (Uint32) this->spec.samples * 1000 / this->spec.freq;
+    SDL_Delay(delay ? delay : 1);
+}
+
+static int
+LUNIXAUDIO_ApplyFormat(_THIS, int sampleRate)
+{
+    struct audio_format requested;
+    struct audio_format actual;
+    int info = -1;
+
+    requested.sample_rate = sampleRate;
+    requested.channels = 2;
+    requested.encoding = AUDIO_ENCODING_S16_LE;
+    requested.bits_per_sample = 16;
+    requested.frame_size = 4;
+
+    errno = posix_devctl(this->hidden->audio_fd, AUDIO_SET_FORMAT, &requested,
+            sizeof(requested), &info);
+    if (errno != 0 || info != 0) {
+        return -1;
+    }
+
+    actual = requested;
+    info = -1;
+    errno = posix_devctl(this->hidden->audio_fd, AUDIO_GET_FORMAT, &actual,
+            sizeof(actual), &info);
+    if (errno != 0 || info != 0) {
+        actual = requested;
+    }
+
+    if (actual.channels != 2 || actual.encoding != AUDIO_ENCODING_S16_LE ||
+            actual.bits_per_sample != 16 || actual.frame_size != 4) {
+        return SDL_SetError("Unsupported /dev/audio format");
+    }
+
+    this->spec.freq = actual.sample_rate;
+    this->spec.format = AUDIO_S16LSB;
+    this->spec.channels = actual.channels;
+    return 0;
+}
+
+static void
+LUNIXAUDIO_PlayDevice(_THIS)
+{
+    Uint8 *buffer = this->hidden->mixbuf;
+    int remaining = this->hidden->mixlen;
+
+    while (remaining > 0) {
+        ssize_t bytes = write(this->hidden->audio_fd, buffer, remaining);
+        if (bytes > 0) {
+            buffer += bytes;
+            remaining -= bytes;
+            continue;
+        }
+
+        if (bytes < 0 && errno == EINTR) {
+            continue;
+        }
+
+        SDL_OpenedAudioDeviceDisconnected(this);
+        break;
+    }
+}
+
+static Uint8 *
+LUNIXAUDIO_GetDeviceBuf(_THIS)
+{
+    return this->hidden->mixbuf;
+}
+
+static void
+LUNIXAUDIO_PrepareToClose(_THIS)
+{
+    int info = -1;
+    errno = posix_devctl(this->hidden->audio_fd, AUDIO_DRAIN, NULL, 0, &info);
+    (void) info;
+}
+
+static void
+LUNIXAUDIO_CloseDevice(_THIS)
+{
+    if (this->hidden != NULL) {
+        if (this->hidden->audio_fd >= 0) {
+            close(this->hidden->audio_fd);
+        }
+        SDL_free(this->hidden->mixbuf);
+        SDL_free(this->hidden);
+    }
+}
+
+static int
+LUNIXAUDIO_OpenDevice(_THIS, void *handle, const char *devname, int iscapture)
+{
+    const int requestedFreq = this->spec.freq;
+    int firstFreq;
+    int secondFreq;
+    (void) handle;
+    (void) devname;
+
+    if (iscapture) {
+        return SDL_SetError("Lunix audio capture is not supported");
+    }
+
+    this->hidden = (struct SDL_PrivateAudioData *) SDL_calloc(1,
+            sizeof(*this->hidden));
+    if (this->hidden == NULL) {
+        return SDL_OutOfMemory();
+    }
+
+    this->hidden->audio_fd = open(lunixAudioDevice, O_WRONLY);
+    if (this->hidden->audio_fd < 0) {
+        return SDL_SetError("Couldn't open %s: %s", lunixAudioDevice,
+                strerror(errno));
+    }
+
+    this->spec.format = AUDIO_S16LSB;
+    this->spec.channels = 2;
+
+    if (requestedFreq == 44100 || requestedFreq == 48000) {
+        firstFreq = requestedFreq;
+        secondFreq = requestedFreq == 44100 ? 48000 : 44100;
+    } else if (SDL_abs(requestedFreq - 48000) <= SDL_abs(requestedFreq - 44100)) {
+        firstFreq = 48000;
+        secondFreq = 44100;
+    } else {
+        firstFreq = 44100;
+        secondFreq = 48000;
+    }
+
+    if (LUNIXAUDIO_ApplyFormat(this, firstFreq) < 0 &&
+            LUNIXAUDIO_ApplyFormat(this, secondFreq) < 0) {
+        return SDL_SetError("Couldn't configure %s for %d Hz or %d Hz",
+                lunixAudioDevice, firstFreq, secondFreq);
+    }
+
+    SDL_CalculateAudioSpec(&this->spec);
+
+    this->hidden->mixlen = this->spec.size;
+    this->hidden->bytes_per_second = (Uint32) this->spec.freq *
+            this->spec.channels * (SDL_AUDIO_BITSIZE(this->spec.format) / 8);
+    this->hidden->target_queue_bytes = (Uint32) this->hidden->mixlen;
+    this->hidden->mixbuf = (Uint8 *) SDL_malloc(this->hidden->mixlen);
+    if (this->hidden->mixbuf == NULL) {
+        return SDL_OutOfMemory();
+    }
+
+    SDL_memset(this->hidden->mixbuf, this->spec.silence, this->spec.size);
+    return 0;
+}
+
+static int
+LUNIXAUDIO_Init(SDL_AudioDriverImpl *impl)
+{
+    if (access(lunixAudioDevice, W_OK) < 0) {
+        return 0;
+    }
+
+    impl->OpenDevice = LUNIXAUDIO_OpenDevice;
+    impl->WaitDevice = LUNIXAUDIO_WaitDevice;
+    impl->PlayDevice = LUNIXAUDIO_PlayDevice;
+    impl->GetDeviceBuf = LUNIXAUDIO_GetDeviceBuf;
+    impl->PrepareToClose = LUNIXAUDIO_PrepareToClose;
+    impl->CloseDevice = LUNIXAUDIO_CloseDevice;
+    impl->OnlyHasDefaultOutputDevice = 1;
+
+    return 1;
+}
+
+AudioBootStrap LUNIXAUDIO_bootstrap = {
+    "lunix", "Lunix /dev/audio", LUNIXAUDIO_Init, 0
+};
+
+#endif
